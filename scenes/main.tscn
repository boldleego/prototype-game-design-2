[sub_resource type="Shader" id="Shader_vfx82"]
code = "shader_type spatial;\nrender_mode cull_back, diffuse_burley, specular_schlick_ggx;\n\nuniform vec4 color_a : source_color = vec4(0.12, 0.18, 0.25, 1.0);\nuniform vec4 color_b : source_color = vec4(0.78, 0.86, 0.95, 1.0);\nuniform float checker_scale = 14.0;\nuniform float emission_strength = 0.15;\n\nvoid fragment() {\n\tvec2 grid = floor(UV * checker_scale);\n\tfloat checker = mod(grid.x + grid.y, 2.0);\n\tvec3 base = mix(color_a.rgb, color_b.rgb, checker);\n\tALBEDO = base;\n\tROUGHNESS = 0.75;\n\tEMISSION = base * emission_strength;\n}\n"

